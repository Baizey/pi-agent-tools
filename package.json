{
  "name": "pi-agent-tools",
  "version": "0.1.0",
  "description": "Pi package with policy-aware file tools, shell checks, policy introspection, and scoped subagents.",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Baizey/pi-agent-tools.git"
  },
  "homepage": "https://github.com/Baizey/pi-agent-tools#readme",
  "bugs": {
    "url": "https://github.com/Baizey/pi-agent-tools/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "agent-tools",
    "subagents",
    "policy"
  ],
  "pi": {
    "extensions": [
      "./src/extension.ts"
    ],
    "themes": [
      "./themes"
    ]
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc",
    "test": "npm run build && node scripts/run-tests.js"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3"
  },
  "private": true,
  "dependencies": {
    "better-sqlite3": "^12.11.1"
  }
}
